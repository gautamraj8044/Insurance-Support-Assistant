# Required
GROQ_API_KEY=your_groq_api_key_here

# Optional - model configuration
GROQ_MODEL=llama-3.1-8b-instant
GROQ_INTENT_MODEL=llama-3.1-8b-instant
GROQ_TEMPERATURE=0
GROQ_MAX_RETRIES=2
GROQ_TIMEOUT_SECONDS=30

# Optional - paths
DB_PATH=data/insurance_support.db
CHROMA_PATH=./chroma_db
LOG_DIR=logs

# Optional - FAQ dataset
FAQ_DATASET=deccan-ai/insuranceQA-v2
FAQ_SAMPLE_SIZE=500
FAQ_BATCH_SIZE=100
FAQ_TOP_K=3

# Optional - app behaviour
MAX_GRAPH_ITERATIONS=4
DEBUG_MODE=false

# Optional - tracing (requires `pip install arize-phoenix`)
ENABLE_TRACING=false
PHOENIX_COLLECTOR_ENDPOINT=http://127.0.0.1:6006/v1/traces
