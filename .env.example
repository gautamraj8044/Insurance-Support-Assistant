# Required
GROQ_API_KEY=your_groq_api_key_here

# Optional - model configuration
GROQ_MODEL=llama-3.1-8b-instant
GROQ_INTENT_MODEL=llama-3.1-8b-instant
GROQ_TEMPERATURE=0
GROQ_MAX_RETRIES=2
GROQ_TIMEOUT_SECONDS=30

# Optional - paths
DB_PATH=data/insurance_support.db
CHROMA_PATH=./chroma_db
LOG_DIR=logs

# Optional - FAQ dataset
FAQ_DATASET=deccan-ai/insuranceQA-v2
FAQ_SAMPLE_SIZE=500
FAQ_BATCH_SIZE=100
FAQ_TOP_K=3

# Optional - app behaviour
MAX_GRAPH_ITERATIONS=4
DEBUG_MODE=false

# Optional - Phoenix tracing
# pip install arize-phoenix-otel openinference-instrumentation-langchain
#
# Local / self-hosted Phoenix (e.g. running via Docker - no API key needed):
#   docker run -p 6006:6006 arizephoenix/phoenix:latest
ENABLE_TRACING=true
PHOENIX_COLLECTOR_ENDPOINT=http://localhost:6006/v1/traces
PHOENIX_PROJECT_NAME=multi-agent-insurance
#
# Phoenix Cloud instead (https://app.phoenix.arize.com - Settings > API Keys):
# PHOENIX_COLLECTOR_ENDPOINT=https://app.phoenix.arize.com
# PHOENIX_API_KEY=
